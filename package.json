{
  "name": "antigravity-mcp",
  "version": "1.2.0",
  "description": "MCP server for Antigravity (agy) and Gemini AI — supports Google account via agy or direct API key via SDK",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "antigravity-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "node scripts/run-tests.mjs",
    "lint": "tsc --noEmit",
    "contribute": "tsx src/contribute.ts",
    "prepublishOnly": "echo '⚠️  Remember to test locally first!' && npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "gemini",
    "antigravity",
    "agy",
    "ai",
    "llm"
  ],
  "author": "ia23a-lachnita",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ia23a-lachnita/antigravity-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ia23a-lachnita/antigravity-mcp/issues"
  },
  "homepage": "https://github.com/ia23a-lachnita/antigravity-mcp#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@ai-sdk/google": "^3.0.83",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "ai": "^6.0.208",
    "chalk": "^5.0.0",
    "d3-shape": "^3.2.0",
    "inquirer": "^9.0.0",
    "prismjs": "^1.30.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "archiver": "^7.0.1",
    "mermaid": "^11.9.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitepress": "^1.6.3",
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "publishConfig": {
    "access": "public"
  }
}
